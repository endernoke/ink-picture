{
  "name": "ink-picture",
  "version": "2.1.0",
  "description": "Better image component for Ink CLI/TUIs",
  "license": "MIT",
  "repository": "https://github.com/endernoke/ink-picture",
  "author": {
    "name": "James Zheng",
    "email": "endernoke@gmail.com",
    "url": "https://github.com/endernoke"
  },
  "type": "module",
  "exports": {
    "types": "./build/index.d.ts",
    "default": "./build/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "format": "biome format --write",
    "example": "node --loader=ts-node/esm --no-warnings examples/protocols.tsx",
    "build": "tsc",
    "prepare": "husky",
    "lint": "biome check",
    "test:unit": "vitest run -c tests/vitest/vitest.config.ts",
    "test:browser": "playwright test -c tests/playwright/playwright.config.ts",
    "test": "tsc --noEmit && biome ci && pnpm test:unit && pnpm test:browser"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "files": ["build"],
  "keywords": [
    "ink",
    "image",
    "photo",
    "display",
    "component",
    "jsx",
    "react",
    "picture",
    "render",
    "viewer",
    "cli",
    "terminal"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.17",
    "@xterm/addon-image": "0.10.0-beta.291",
    "@xterm/xterm": "6.1.0-beta.291",
    "husky": "^9.1.7",
    "ink": "^7.1.0",
    "lint-staged": "^17.0.8",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "ink": ">=5",
    "react": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "is-unicode-supported": "^2.1.0",
    "iterm2-version": "^6.0.0",
    "jimp": "^1.6.1",
    "node-fetch": "^3.3.2",
    "sixel": "^0.16.0",
    "supports-color": "^10.2.2"
  }
}
