{
  "name": "ink-picture",
  "version": "2.0.0",
  "description": "Better image component for Ink CLI/TUIs",
  "license": "MIT",
  "repository": "https://github.com/endernoke/ink-picture",
  "author": {
    "name": "James Zheng",
    "email": "endernoke@gmail.com",
    "url": "https://github.com/endernoke"
  },
  "type": "module",
  "exports": {
    "types": "./build/index.d.ts",
    "default": "./build/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "format": "biome format --write",
    "example": "node --loader=ts-node/esm --no-warnings examples/protocols.tsx",
    "build": "tsc",
    "prepare": "husky",
    "lint": "biome check",
    "test:unit": "vitest run -c tests/vitest/vitest.config.ts",
    "test:browser": "playwright test -c tests/playwright/playwright.config.ts",
    "test": "tsc --noEmit && biome ci && pnpm test:unit && pnpm test:browser"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "files": ["build"],
  "keywords": [
    "ink",
    "image",
    "photo",
    "display",
    "component",
    "jsx",
    "react",
    "picture",
    "render",
    "viewer",
    "cli",
    "terminal"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.1.12",
    "@xterm/addon-image": "0.10.0-beta.197",
    "@xterm/xterm": "6.1.0-beta.197",
    "husky": "^9.1.7",
    "ink": "^7.0.0",
    "lint-staged": "^16.1.6",
    "node-pty": "^1.0.0",
    "react": "^19.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "ink": ">=5",
    "react": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "is-unicode-supported": "^2.1.0",
    "iterm2-version": "^6.0.0",
    "jimp": "^1.6.1",
    "node-fetch": "^3.3.2",
    "sixel": "^0.16.0",
    "supports-color": "^10.2.0"
  }
}
